# Maintainer: Ernesto Cruz Olivera <ecruzolivera@gmail.com>

pkgname=riskie
pkgver=0.1.0
pkgrel=1
pkgdesc="Disk automounting daemon for Linux with system tray support"
arch=('x86_64')
url="https://github.com/ecruzolivera/riskie"
license=('MIT')
install=riskie.install
depends=('udisks2' 'gtk3' 'gettext')
makedepends=('rust' 'cargo' 'gettext')
source=("$pkgname-$pkgver.tar.gz::https://github.com/ecruzolivera/$pkgname/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    cargo build --release --locked
}

package() {
    cd "$pkgname-$pkgver"
    
    # Install binary
    install -Dm755 target/release/riskie "$pkgdir/usr/bin/riskie"
    
    # Install systemd user service
    install -Dm644 contrib/systemd/riskie.service "$pkgdir/usr/lib/systemd/user/riskie.service"
    
    # Install translations
    for po_file in po/*.po; do
        lang=$(basename "$po_file" .po)
        install -dm755 "$pkgdir/usr/share/locale/$lang/LC_MESSAGES"
        msgfmt "$po_file" -o "$pkgdir/usr/share/locale/$lang/LC_MESSAGES/riskie.mo"
    done
    
    # Install license
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    
    # Install README
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}